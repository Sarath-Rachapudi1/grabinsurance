# ── Anthropic (leave blank to use rule-based mock scoring) ──────────────────
ANTHROPIC_API_KEY=

# ── LangSmith observability (leave blank to disable tracing) ───────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=grabinsurance-dev

# ── App ────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./grabinsurance.db
BACKEND_PORT=8000

# ── Mock insurer behaviour ─────────────────────────────────────────────────
# Options: normal | timeout | decline | policy_fail
MOCK_INSURER_SCENARIO=normal
# Webhook callback base (backend calls itself)
WEBHOOK_BASE_URL=http://backend:8000

# ── CORS (add frontend origin) ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000
